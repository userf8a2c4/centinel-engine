# Centinel Engine — variables de entorno requeridas
# Copia este archivo como .env en el servidor del pipeline y rellena los valores.
# NUNCA subas .env al repositorio. El archivo .env está en .gitignore.

# ── SUPABASE ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://PROYECTO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...  # service_role key — NUNCA en el repo
SUPABASE_ANON_KEY=eyJ...          # anon/public key — segura para el panel

# ── GITHUB (emergency publish + pipeline CI) ──────────────────────────────────
# PAT con scope: workflow (para disparar workflow_dispatch en anomalías críticas)
GITHUB_TOKEN=ghp_...
GITHUB_REPOSITORY=userf8a2c4/centinel-engine
GITHUB_REF_NAME=main

# ── PIPELINE ──────────────────────────────────────────────────────────────────
CENTINEL_POLL_INTERVAL=120        # segundos entre capturas (por defecto 120)
CENTINEL_ENDPOINT_TIMEOUT=10.0    # timeout HTTP por request al CNE
OTS_ENABLED=true                  # anclaje Bitcoin via OpenTimestamps

# ── LOGGING ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR
