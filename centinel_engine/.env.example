# === Dial único de seguridad / Single security dial ===
# CENTINEL_MODE controla la cadencia de captura Y deriva la postura de
# seguridad. No necesitas tocar las variables de abajo: el modo elige
# valores seguros por defecto. Verifica con: `centinel doctor`.
#
# CENTINEL_MODE drives capture cadence AND derives the security posture.
# You do not need to set the variables below — the mode picks safe
# defaults. Verify with: `centinel doctor`.
#
#   maintenance : fuera de temporada / off-season  (firma/pinning opcional)
#   monitoring  : vigilancia elevada / elevated     (firma/pinning recomendado)
#   election    : máxima exigencia / maximum        (firma + pinning OBLIGATORIOS)
CENTINEL_MODE=maintenance

# --- Overrides opcionales / Optional overrides ---
# Lo que fijes aquí explícitamente SIEMPRE gana sobre el default del modo
# (sin retrocesos). Déjalos vacíos para que el modo decida.
# Anything you set here explicitly ALWAYS wins over the mode default
# (no regression). Leave blank to let the mode decide.
#
# CENTINEL_REQUIRE_SIGNATURE=true            # forzar evidencia firmada
# CENTINEL_OPERATOR_KEY_PATH=keys/operator_private.pem
# CENTINEL_CNE_CERT_SHA256=                  # huella TLS del CNE (anti-MITM)
# CENTINEL_STATE_HMAC_KEY=                   # >=16 chars; protege el breaker
# CENTINEL_DISABLE_OPENTIMESTAMPS=false      # ancla Bitcoin gratis (OTS)

RPC_URL=https://mainnet.base.org
CHAIN=base
PRIVATE_KEY=0xTU_CLAVE_PRIVADA
BATCH_INTERVAL_HOURS=
HEARTBEAT_INTERVAL_HOURS=
ENABLE_BLOB_TX=false
MAX_FEE_GWEI=0.05
MAX_PRIORITY_FEE_GWEI=0.01

# ── PRIVACIDAD / IP ANONYMIZATION ─────────────────────────────────────────
# Activa modo privacidad: rotación de proxy en cada request, suprime my_url
# en gossip. Los nodos no son identificables por IP en la red P2P.
# Enables privacy mode: per-request proxy rotation, suppresses my_url in
# gossip. Nodes are not identifiable by IP on the P2P network.
# CENTINEL_PRIVACY_MODE=true

# Enruta TODOS los requests de monitoreo CNE a través de Tor (requiere daemon Tor activo).
# socks5h:// fuerza la resolución DNS dentro de Tor (previene DNS leaks).
# Routes ALL CNE monitoring requests through Tor (requires Tor daemon running).
# socks5h:// forces DNS resolution inside Tor (prevents DNS leaks).
# CENTINEL_TOR_ENABLED=true

# Puerto SOCKS5 del daemon Tor (defecto: 9050).
# Tor daemon SOCKS5 port (default: 9050).
# CENTINEL_TOR_PORT=9050

# Lista de proxies alternativos (si no se usa Tor). Separados por coma.
# Comma-separated fallback proxy list (if not using Tor).
# PROXY_LIST=socks5h://proxy1:1080,http://user:pass@proxy2:8080

# ══════════════════════════════════════════════════════════════════════════════
# POLITE SCRAPING — Control de carga para enjambres distribuidos
# POLITE SCRAPING — Load control for distributed swarms
# ══════════════════════════════════════════════════════════════════════════════

# ES: Jitter aleatorio (segundos) antes de iniciar cada ciclo de descarga completo.
#     Distribuye los nodos en el tiempo y evita que N nodos golpeen el CNE al mismo segundo.
#     Valor 0 = sin jitter (no recomendado en producción con múltiples nodos).
# EN: Random jitter (seconds) before starting each download cycle.
#     Distributes node start times, preventing N nodes from hitting CNE simultaneously.
#     Value 0 = no jitter (not recommended in production with multiple nodes).
CENTINEL_SCRAPE_JITTER_SECONDS=30

# ES: Filtro opcional de fuentes activas (source_ids separados por coma).
#     Si no se define: el nodo raspa TODAS las fuentes del config del país activo.
#     Si se define: solo raspa los source_ids listados. Los IDs desconocidos se ignoran con WARNING.
#     Fail-safe: si TODOS los IDs pedidos son inválidos → raspa todo (nunca silencia el nodo).
#
# EN: Optional active sources filter (comma-separated source_ids).
#     If unset: the node scrapes ALL sources in the active country config.
#     If set: only scrapes the listed source_ids. Unknown IDs are ignored with WARNING.
#     Fail-safe: if ALL requested IDs are invalid → scrapes everything (never silences the node).
#
# Source IDs disponibles — Honduras (command_center/config.yaml):
# Available Source IDs — Honduras (command_center/config.yaml):
#
#   NACIONAL              — Resultado presidencial nacional / National presidential result
#   01_atlantida          — Atlántida
#   02_choluteca          — Choluteca
#   03_colon              — Colón
#   04_comayagua          — Comayagua
#   05_copan              — Copán
#   06_cortes             — Cortés
#   07_el_paraiso         — El Paraíso
#   08_francisco_morazan  — Francisco Morazán (incluye Tegucigalpa / includes Tegucigalpa)
#   09_gracias_a_dios     — Gracias a Dios
#   10_intibuca           — Intibucá
#   11_islas_de_la_bahia  — Islas de la Bahía
#   12_la_paz             — La Paz
#   13_lempira            — Lempira
#   14_ocotepeque         — Ocotepeque
#   15_olancho            — Olancho
#   16_santa_barbara      — Santa Bárbara
#   17_valle              — Valle
#   18_yoro               — Yoro
#
# Ejemplos / Examples:
#   Solo el nacional:     CENTINEL_ACTIVE_SOURCES=NACIONAL
#   Zona norte:           CENTINEL_ACTIVE_SOURCES=NACIONAL,06_cortes,16_santa_barbara,01_atlantida
#   Un departamento:      CENTINEL_ACTIVE_SOURCES=08_francisco_morazan
#   (vacío / empty)       → raspa todo / scrape everything
CENTINEL_ACTIVE_SOURCES=
